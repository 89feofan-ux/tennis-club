{
  "builds": [
    { "src": "api/data.py", "use": "@vercel/python" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.js", "use": "@vercel/static" },
    { "src": "*.css", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/data" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
